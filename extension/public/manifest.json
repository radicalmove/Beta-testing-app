{
  "manifest_version": 3,
  "name": "Moodle Course Review",
  "version": "0.0.0",
  "description": "Private course review tools for configured Moodle sites.",
  "key": "",
  "permissions": ["identity", "storage", "scripting", "webNavigation"],
  "host_permissions": ["https://moodle.example.invalid/*", "https://review.example.invalid/*"],
  "optional_host_permissions": ["https://rise.example.invalid/*", "https://scorm.example.invalid/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{
    "matches": ["https://moodle.example.invalid/*"],
    "js": ["content.js"],
    "all_frames": true,
    "match_about_blank": true,
    "match_origin_as_fallback": true,
    "run_at": "document_idle"
  }],
  "content_security_policy": { "extension_pages": "script-src 'self'; object-src 'none'" }
}
