# Copy to .env, chmod 600, and replace every replace-* value. Never commit .env.
# Compose commands must include --env-file .env so these values are interpolated.
POSTGRES_DB=course_review
POSTGRES_USER=course_review
POSTGRES_PASSWORD=replace-with-a-long-unique-password
DATABASE_URL=postgresql+psycopg://course_review:replace-with-a-long-unique-password@db:5432/course_review
API_PORT=8000
SESSION_SECRET=replace-with-at-least-32-random-bytes
ATTACHMENT_STORAGE_DIR=/data/attachments
ATTACHMENT_MAX_BYTES=10485760
SERVICE_ORIGIN=https://review-host.your-tailnet.ts.net
MOODLE_HOST_PATTERNS=https://my.uconline.ac.nz/*
EXTENSION_REDIRECT_URIS=https://replace-with-stable-chrome-id.chromiumapp.org/,https://replace-with-stable-edge-id.chromiumapp.org/
# Run `python -m app.bootstrap` once after migrations, with these two deployment
# secrets set, to provision the first administrator. Do not use public registration.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_DISPLAY_NAME=Course Review Administrator
BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-long-unique-password
