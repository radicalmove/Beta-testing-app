# Copy this file to .env and replace the password before starting the service.
# Compose commands must include --env-file .env so these values are interpolated.
POSTGRES_DB=course_review
POSTGRES_USER=course_review
POSTGRES_PASSWORD=replace-with-a-long-unique-password
DATABASE_URL=postgresql+psycopg://course_review:replace-with-a-long-unique-password@db:5432/course_review
API_PORT=8000
# Run `python -m app.bootstrap` once after migrations, with these two deployment
# secrets set, to provision the first administrator. Do not use public registration.
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-long-unique-password
